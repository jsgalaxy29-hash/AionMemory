@using Aion.AppHost.Services.Rendering
@using Microsoft.AspNetCore.Components.Forms

<InputDate TValue="DateTime?" class="input" data-field-renderer="date" Value="@FieldValueConverters.ToDateTimeValue(Value)" ValueChanged="OnValueChanged" disabled="@Disabled" />

@code {
    [Parameter, EditorRequired] public FormFieldRenderModel Field { get; set; } = default!;
    [Parameter] public object? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<object?> ValueChanged { get; set; }

    private Task OnValueChanged(DateTime? value) => ValueChanged.InvokeAsync(value);
}
