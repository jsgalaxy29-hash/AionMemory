@using Aion.AppHost.Services.Rendering

<select class="input" data-field-renderer="select" @onchange="OnChanged" disabled="@Disabled">
    <option value="">Sélectionner…</option>
    @foreach (var option in Field.Options)
    {
        <option value="@option" selected="@(string.Equals(FieldValueConverters.ToStringValue(Value), option, StringComparison.OrdinalIgnoreCase))">@option</option>
    }
</select>

@code {
    [Parameter, EditorRequired] public FormFieldRenderModel Field { get; set; } = default!;
    [Parameter] public object? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<object?> ValueChanged { get; set; }

    private Task OnChanged(ChangeEventArgs args) => ValueChanged.InvokeAsync(args.Value?.ToString());
}
