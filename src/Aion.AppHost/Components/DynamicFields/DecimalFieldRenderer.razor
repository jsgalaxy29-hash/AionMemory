@using Aion.AppHost.Services.Rendering
@using Microsoft.AspNetCore.Components.Forms

<InputNumber TValue="decimal?" class="input" data-field-renderer="decimal" Value="@FieldValueConverters.ToDecimalValue(Value)" ValueChanged="OnValueChanged" disabled="@Disabled" />

@code {
    [Parameter, EditorRequired] public FormFieldRenderModel Field { get; set; } = default!;
    [Parameter] public object? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<object?> ValueChanged { get; set; }

    private Task OnValueChanged(decimal? value) => ValueChanged.InvokeAsync(value);
}
