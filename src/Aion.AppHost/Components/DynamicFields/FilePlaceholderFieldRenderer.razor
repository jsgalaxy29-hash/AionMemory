@using Aion.AppHost.Services.Rendering
@using Microsoft.AspNetCore.Components.Forms

<InputText class="input"
           data-field-renderer="file-placeholder"
           Value="@FieldValueConverters.ToStringValue(Value)"
           ValueChanged="OnValueChanged"
           placeholder="@Field.Placeholder"
           disabled="true" />

@code {
    [Parameter, EditorRequired] public FormFieldRenderModel Field { get; set; } = default!;
    [Parameter] public object? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<object?> ValueChanged { get; set; }

    private Task OnValueChanged(string? value) => ValueChanged.InvokeAsync(value);
}
