@using Aion.AppHost.Services.Rendering

<span data-list-cell-renderer="file">@(string.IsNullOrWhiteSpace(ListCellValueFormatter.ToText(Value)) ? "—" : "Fichier")</span>

@code {
    [Parameter, EditorRequired] public ListColumnRenderModel Column { get; set; } = default!;
    [Parameter] public object? Value { get; set; }
}
